APP_NAME=TurneroYa
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_KEY=

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=turneroya
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=true

# Content Templates aprobados por Meta (Twilio Console > Content Builder)
# Si están vacíos, los recordatorios/confirmaciones caen a texto plano sin botones.
TWILIO_REMINDER_CONTENT_SID=
TWILIO_CONFIRMATION_CONTENT_SID=

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxx
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxx
MERCADOPAGO_WEBHOOK_SECRET=

# Email (SMTP o Resend)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@turneroya.app
MAIL_FROM_NAME="TurneroYa"
RESEND_API_KEY=

# Cron
CRON_SECRET=cambiar-en-produccion

# Billing (suscripciones recurrentes)
# Mismos tokens de MERCADOPAGO_ACCESS_TOKEN arriba se reutilizan para Preapproval.
# El webhook debe estar configurado en: https://www.mercadopago.com.ar/developers → tu app → Webhooks
#   Eventos: payment, subscription_preapproval, subscription_authorized_payment
#   URL:     {APP_URL}/api/webhook/mercadopago
